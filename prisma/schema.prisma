  bannedById       BigInt
  active           Boolean   @default(true)
  duration         Int?
  expiresAt        DateTime?
  createdAt        DateTime  @default(now())
  unbannedAt       DateTime?
  unbannedById     BigInt?
  workspace        workspace @relation(fields: [workspaceGroupId], references: [groupId])

  @@index([workspaceGroupId, userId, active])
  @@index([workspaceGroupId, active])
}

model PlayerReport {
  id               String    @id @default(uuid()) @db.Uuid
  workspaceGroupId BigInt
  reporterUserId   BigInt
  reportedUserId   BigInt?
  reason           String
  description      String?
  jobId            String
  status           String    @default("pending")
  reviewedById     BigInt?
  reviewNote       String?
  resolvedAt       DateTime?
  createdAt        DateTime  @default(now())
  workspace        workspace @relation(fields: [workspaceGroupId], references: [groupId])

  @@index([workspaceGroupId, status])
  @@index([workspaceGroupId, createdAt])
}

model AdminMessageLog {
  id               String    @id @default(uuid()) @db.Uuid
  workspaceGroupId BigInt
  sentById         BigInt
  targetUserId     BigInt?
  message          String
  jobId            String
  createdAt        DateTime  @default(now())
  workspace        workspace @relation(fields: [workspaceGroupId], references: [groupId])

  @@index([workspaceGroupId, createdAt])
}

model Recommendation {
  id               String                   @id @default(uuid()) @db.Uuid
  workspaceGroupId BigInt
  targetUserId     BigInt
  targetUsername    String
  targetPicture    String?
  reason           String
  status           String                   @default("active")
  recommendedRankId   Int?
  recommendedRankName String?
  createdById      BigInt
  createdByName    String?
  editedById       BigInt?
  editedByName     String?
  editedAt         DateTime?
  statusChangedById   BigInt?
  statusChangedByName String?
  statusChangedAt     DateTime?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  votes            RecommendationVote[]
  comments         RecommendationComment[]
  workspace        workspace                @relation(fields: [workspaceGroupId], references: [groupId])

  @@index([workspaceGroupId, status])
  @@index([workspaceGroupId, createdAt])
  @@index([targetUserId])
}

model RecommendationVote {
  id               String         @id @default(uuid()) @db.Uuid
  recommendationId String         @db.Uuid
  userId           BigInt
  createdAt        DateTime       @default(now())
  recommendation   Recommendation @relation(fields: [recommendationId], references: [id], onDelete: Cascade)

  @@unique([recommendationId, userId])
  @@index([recommendationId])
}

model RecommendationComment {
