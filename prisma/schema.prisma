  recommendationId String         @db.Uuid
  authorId         BigInt
  authorName       String?
  authorPicture    String?
  content          String
  image            String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  recommendation   Recommendation @relation(fields: [recommendationId], references: [id], onDelete: Cascade)

  @@index([recommendationId, createdAt])
}

model Notification {
  id               String    @id @default(uuid()) @db.Uuid
  userId           BigInt
  workspaceGroupId BigInt
  type             String
  title            String
  body             String
  href             String?
  read             Boolean   @default(false)
  createdAt        DateTime  @default(now())
  user             user      @relation(fields: [userId], references: [userid], onDelete: Cascade)
  workspace        workspace @relation(fields: [workspaceGroupId], references: [groupId], onDelete: Cascade)

  @@index([userId, workspaceGroupId, read])
  @@index([userId, workspaceGroupId, createdAt])
}

model ModerationCase {
  id               String               @id @default(uuid()) @db.Uuid
  workspaceGroupId BigInt
  targetUserId     BigInt
  targetUsername   String?
  reportedBy       BigInt?
  createdBy        BigInt
  reason           String
  description      String?
  status           String               @default("open")
  action           String?
  createdAt        DateTime             @default(now())
  resolvedAt       DateTime?
  resolvedBy       BigInt?
  expiresAt        DateTime?
  internalNotes    String?
  publicNote       String?
  banDuration      Int?
  isPermanent      Boolean              @default(false)
  revokedAt        DateTime?
  revokedBy        BigInt?
  revokeReason     String?
  placeIds         BigInt[]             @default([])
  workspace        workspace            @relation(fields: [workspaceGroupId], references: [groupId])
  targetUser       user                 @relation("TargetModerationCases", fields: [targetUserId], references: [userid])
  createdByUser    user                 @relation("CreatedModerationCases", fields: [createdBy], references: [userid])
  resolvedByUser   user?                @relation("ResolvedModerationCases", fields: [resolvedBy], references: [userid])
  reportedByUser   user?                @relation("ReportedModerationCases", fields: [reportedBy], references: [userid])
  revokedByUser    user?                @relation("RevokedModerationCases", fields: [revokedBy], references: [userid])
  evidence         ModerationEvidence[]

  @@index([workspaceGroupId, status])
  @@index([targetUserId, workspaceGroupId])
  @@index([createdAt])
}

model ModerationEvidence {
  id          String         @id @default(uuid()) @db.Uuid
  caseId      String         @db.Uuid
  uploadedBy  BigInt
  fileUrl     String
  fileName    String
  fileType    String
  fileSize    Int
  description String?
  createdAt   DateTime       @default(now())
  case        ModerationCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  uploader    user           @relation(fields: [uploadedBy], references: [userid])

  @@index([caseId])
  @@index([uploadedBy])
}

model ModerationLog {
  id               String    @id @default(uuid()) @db.Uuid
  workspaceGroupId BigInt
  actionBy         BigInt
  action           String
  targetUser       BigInt?
  targetUsername   String?
  caseId           String?   @db.Uuid
  details          Json?
  createdAt        DateTime  @default(now())
  workspace        workspace @relation(fields: [workspaceGroupId], references: [groupId])
  actor            user      @relation(fields: [actionBy], references: [userid])

  @@index([workspaceGroupId, createdAt])
  @@index([actionBy])
  @@index([targetUser])
}